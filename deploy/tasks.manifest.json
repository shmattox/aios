{
  "$comment": "Substrate-tagged task topology. NO env_root fact here - the installer receives it. body_path is plugin-root-relative. substrate: 'native' = OS-native scheduler (Task Scheduler / launchd), 'schedule-cloud' = /schedule, 'manual' = in-session only. cron fields are plain integers (min hour dom mon dow) - the registrars do NOT parse ranges/lists/steps.",
  "tasks": [
    { "id": "aios-capture-router",  "substrate": "native", "cron": "15 1 * * *", "type": "script", "script": "engine/tools/capture_router_task.py", "body_path": "deploy/tasks/capture-router.md",  "allowed_tools": ["Read","Glob","Grep","Bash(python:*)"], "enabled": true,  "context_stages": ["capture-router"], "description": "Route raw captures from auto/ intake into the KB inboxes (deterministic script; no model)." },
    { "id": "aios-meetings-router", "substrate": "native", "cron": "45 1 * * *", "type": "script", "script": "engine/tools/meetings_router_task.py", "body_path": "deploy/tasks/meetings-router.md", "allowed_tools": ["Read","Glob","Grep","Bash(python:*)"], "enabled": false, "context_stages": [], "description": "Route Granola meeting notes from 00_Inbox/meetings/ into state/domains/<silo>/meetings/ by Granola folder (deterministic script; no model). Opt-in — Granola-specific." },
    { "id": "aios-session-capture", "substrate": "native", "cron": "32 1 * * *", "body_path": "deploy/tasks/session-capture.md", "allowed_tools": ["Read","Write","Glob","Grep","Bash(python:*)","Bash(cd:*)","Bash(git log:*)","Bash(git show:*)"], "max_turns": 150, "enabled": true,  "context_stages": ["session-capture"], "description": "Synthesize Claude Code session evidence into raw/sessions/ records." },
    { "id": "aios-ingest",          "substrate": "native", "cron": "0 2 * * *",  "body_path": "deploy/tasks/ingest.md",          "allowed_tools": ["Read","Write","Glob","Grep","Bash(python:*)","Bash(cd:*)"], "max_turns": 200, "enabled": true,  "context_stages": ["capture+sort+ingest","ingest"], "description": "Capture+sort+ingest Phase A: draft queue items into vault staging." },
    { "id": "aios-reflect",         "substrate": "native", "cron": "30 2 * * *", "body_path": "deploy/tasks/reflect.md",         "allowed_tools": ["Read","Write","Glob","Grep","Bash(python:*)","Bash(cd:*)"], "max_turns": 150, "enabled": false, "context_stages": ["reflect"], "description": "Daily distillation (opt-in): draft review-lane Lessons/knowledge/decisions/journal proposals from yesterday's session records. No git, Notion, or Drive." },
    { "id": "aios-gate-auto",       "substrate": "native", "cron": "0 4 * * *",  "body_path": "deploy/tasks/gate-auto.md",       "allowed_tools": ["Read","Write","Glob","Grep","Bash(python:*)","Bash(cd:*)"], "max_turns": 400, "enabled": true,  "report_only_drops": ["Write"], "context_stages": ["gate-auto"], "description": "Unattended Phase B: ships ONLY opted-in auto-ship KBs; review+tripwire moat." },
    { "id": "aios-garden",          "substrate": "native", "cron": "10 3 * * 0", "body_path": "deploy/tasks/garden.md",          "allowed_tools": ["Read","Write","Glob","Grep","Bash(python:*)","Bash(cd:*)"], "model": "sonnet", "max_turns": 150, "enabled": true,  "context_stages": ["garden"], "description": "Weekly vault garden: mechanical sweep + review-lane proposals." },
    { "id": "aios-brief-cache",     "substrate": "native", "cron": "50 6 * * *", "body_path": "deploy/tasks/brief-cache.md",     "allowed_tools": ["Read","Write","Glob","Grep","Bash(python:*)","Bash(cd:*)"], "model": "sonnet", "max_turns": 150, "enabled": true, "context_stages": ["brief"], "description": "Brief precompute cache-writer (optional; Notion-wired installs benefit most)." },
    { "id": "aios-gate",            "substrate": "manual",         "cron": null,          "body_path": "deploy/tasks/gate.md",            "allowed_tools": [], "enabled": true,  "description": "Human-gated Phase B - run in-session via /aios:gate. Never scheduled." },
    { "id": "aios-inbox-capture",   "substrate": "manual",         "cron": null,          "body_path": "deploy/tasks/inbox-capture.md",   "allowed_tools": [], "enabled": true,  "description": "MCP-source capture (gmail/drive) - session-run; scheduling needs authenticated MCP." },
    { "id": "aios-cloud-ingest",    "substrate": "schedule-cloud", "cron": "0 8 * * *",  "body_path": "deploy/cloud/ingest.md",          "allowed_tools": [], "enabled": false, "description": "No-always-on-desktop variant - register manually via /schedule; clear MCP connectors to zero." },
    { "id": "aios-cloud-gate-auto", "substrate": "schedule-cloud", "cron": "0 10 * * *", "body_path": "deploy/cloud/gate-auto.md",       "allowed_tools": [], "enabled": false, "description": "Cloud variant of gate-auto (UTC crons; pull-first/push-both)." },
    { "id": "aios-cloud-garden",    "substrate": "schedule-cloud", "cron": "0 12 * * 0", "body_path": "deploy/cloud/garden.md",          "allowed_tools": [], "enabled": false, "description": "Cloud variant of garden." }
  ]
}
